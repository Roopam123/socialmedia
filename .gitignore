cd /Users/roopam/Desktop/AIM/backend && cat > .gitignore <<'EOF'
# Node.js dependencies
node_modules/

# Optional npm cache directory
.npm

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory
coverage/
*.lcov

# nyc test coverage
.nyc_output/

# Grunt intermediate storage (http://gruntjs.com/)
.grunt/

# Dependency directories
bower_components/

# Optional REPL history
.node_repl_history

# dotenv environment variables file
.env

# MacOS files
.DS_Store

# VS Code settings
.vscode/

# Build output
dist/
build/

# Uploaded file storage
uploads/

# Misc
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

EOF